# AgriMentor Environment Variables
# Copy this file to .env and fill in your API keys

# Backend port (default: 3001)
PORT=3001

# ========== WEATHER (OpenWeatherMap) ==========
# Get a free key at https://openweathermap.org/api
# You can use OPENWEATHERMAP_API_KEY or WEATHER_API_KEY (same value)
# Do not commit real keys — copy this file to .env and paste your key there
WEATHER_API_KEY=b20a19b8960c58fd60b8ded20e30638b
# WEATHER_API_KEY=

# ========== MARKET (data.gov.in AGMARKNET) ==========
# Get an API key at https://data.gov.in (register and get from My Account)
# Resource ID for Variety-wise Daily Market Prices
DATA_GOV_IN_API_KEY= 579b464db66ec23bdd000001cdd3946e44ce4aad7209ff7b23ac571b

DATA_GOV_IN_RESOURCE_ID=35985678-0d79-46b4-9ed6-6f13308a1d24

# ========== DISEASE DETECTION (Plant.id) ==========
# Get a free key at https://admin.kindwise.com/signup
PLANT_ID_API_KEY=your-plant-id-api-key

# ========== OPTIONAL ==========
# Frontend: API base URL (only if backend runs on different host/port)
# VITE_API_URL=http://localhost:3001
